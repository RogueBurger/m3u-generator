{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "M3U Creator",
  "version": "0.1.0",
  "identifier": "com.m3ucreator.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "M3U Creator",
        "width": 640,
        "height": 480,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
